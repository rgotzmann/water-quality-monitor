# WaterRich — Environment Config

# Kafka
KAFKA_BOOTSTRAP=localhost:9092
INPUT_TOPIC=WaterRich.readings.raw
ALERT_TOPIC=WaterRich.alerts.active
RESP_TOPIC=WaterRich.reco_responses

# Data
SNAPSHOT_DIR=snapshots/readings
SNAPSHOT_GLOB=snapshots/readings/**/*.parquet
DATA_CSV=data/usgs_water_quality.csv

# Model
REGISTRY_DIR=model_registry
MODEL_VERSION=isolation_forest_v1
CONTAMINATION=0.05
TEST_FRAC=0.2
ALERT_THRESHOLD=-0.1

# API
API_PORT=8080
